# ═══════════════════════════════════════════════════════════════════════════
# ICMS Project - Global .gitignore
# Chặn các file không cần thiết trước khi push lên GitHub
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# 📄 MARKDOWN FILES (Tài liệu - không cần commit)
# ═══════════════════════════════════════════════════════════════════════════
*.md

# ═══════════════════════════════════════════════════════════════════════════
# 🦀 RUST BUILD FILES (Backend)
# ═══════════════════════════════════════════════════════════════════════════
backend/target/
backend/Cargo.lock
backend/**/*.rs.bk
backend/**/*.swp
backend/**/*.swo

# ═══════════════════════════════════════════════════════════════════════════
# 📦 NODE.JS / REACT BUILD FILES (Frontend)
# ═══════════════════════════════════════════════════════════════════════════
frontend-TU/node_modules/
frontend-TU/dist/
frontend-TU/build/
frontend-TU/.vite/
frontend-TU/npm-debug.log
frontend-TU/npm-debug.log*
frontend-TU/yarn-debug.log*
frontend-TU/yarn-error.log*
frontend-TU/.pnpm-debug.log*
frontend-TU/pnpm-debug.log*

# ═══════════════════════════════════════════════════════════════════════════
# 🔐 ENVIRONMENT & SECRET FILES
# ═══════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production.local
backend/.env
frontend-TU/.env
frontend-TU/.env.local

# ═══════════════════════════════════════════════════════════════════════════
# 📊 LOG FILES
# ═══════════════════════════════════════════════════════════════════════════
*.log
logs/
logs.txt
build.log
check.log

# ═══════════════════════════════════════════════════════════════════════════
# 🪟 WINDOWS SPECIFIC FILES (OS Junk)
# ═══════════════════════════════════════════════════════════════════════════
Thumbs.db
Desktop.ini
*.lnk
.DS_Store
$RECYCLE.BIN/
ehthumbs.db
[Dd]esktop.ini
[Dd]esktop.lnk

# ═══════════════════════════════════════════════════════════════════════════
# 💾 IDE & EDITOR FILES
# ═══════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
*.code-workspace
.DS_Store

# ═══════════════════════════════════════════════════════════════════════════
# 🐳 DOCKER & BUILD FILES
# ═══════════════════════════════════════════════════════════════════════════
*.tar.gz
*.tar
docker-compose.override.yml

# ═══════════════════════════════════════════════════════════════════════════
# 🔧 TEMPORARY & CACHE FILES
# ═══════════════════════════════════════════════════════════════════════════
*.tmp
*.cache
*.bak
*.swp
*.swo
.tmp/
tmp/
temp/

# ═══════════════════════════════════════════════════════════════════════════
# 📁 DIRECTORIES TO IGNORE
# ═══════════════════════════════════════════════════════════════════════════
node_modules/
dist/
build/
target/
.vite/
.next/
out/

# ═══════════════════════════════════════════════════════════════════════════
# 📊 GENERATED REPORTS & ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════
*.html
!index.html
coverage/
.nyc_output/

# ═══════════════════════════════════════════════════════════════════════════
# 🧪 TEST & DEBUGGING
# ═══════════════════════════════════════════════════════════════════════════
.pytest_cache/
__pycache__/
*.pyc
.mocha.opts
.coverage
